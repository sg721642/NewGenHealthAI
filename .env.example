# ─── NewGenHealthAI — Environment Variables ───
# Copy this file to .env and fill in your actual keys.
# NEVER commit the .env file to version control.

# ── API Keys (required) ──
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# ── Session Security ──
# A random hex string for signing session cookies.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=your_session_secret_key_here

# ── Optional Path Overrides ──
# LOG_DIR=/custom/path/to/logs
# CHAT_DB_PATH=/custom/path/to/susham_health.db
# VECTOR_STORE_DIR=/custom/path/to/vector_store
# PDF_PATH=/custom/path/to/medical_book.pdf
